<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="AnkiConnect Server"
        android:textColor="#2C3E50"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Switch
        android:id="@+id/switch_server"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="サーバー停止中"
        android:textColor="#34495E"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="2dp">
        <TextView android:id="@+id/tv_perm_storage" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ストレージ権限：確認中..." />
        <TextView android:id="@+id/tv_perm_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="通知権限：確認中..." />
        <Button android:id="@+id/btn_request_perms" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="権限を許可する" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="2dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Ankiプロジェクトフォルダ" android:textSize="12sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn_anki_folder" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="選択" />
            <TextView android:id="@+id/tv_anki_folder" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="未設定" android:singleLine="true" android:ellipsize="middle" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="2. ログ保存フォルダ" android:textSize="12sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn_log_folder" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="選択" />
            <TextView android:id="@+id/tv_log_folder" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="未設定" android:singleLine="true" android:ellipsize="middle" />
        </LinearLayout>
    </LinearLayout>

    <CheckBox android:id="@+id/cb_dev_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="開発者モード (詳細ログを表示)" />

    <ScrollView
        android:id="@+id/scroll_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="#2C3E50"
        android:padding="12dp"
        android:visibility="gone">
        <TextView android:id="@+id/tv_logs" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="monospace" android:textColor="#ECF0F1" android:textSize="12sp" />
    </ScrollView>
</LinearLayout>